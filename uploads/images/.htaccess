# 1. Prevent directory browsing
Options -Indexes

# 2. Only allow specific image types
<FilesMatch "\.(?i:jpe?g|gif|png|webp)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# 3. Block everything else (especially .php, .js, .exe)
<FilesMatch "\.(?i:php|phtml|php3|php4|php5|phps|js|exe|pl|py|sh)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# 4. Force images to be handled as data, not code
php_flag engine off
AddHandler default-handler .php .phtml .php3